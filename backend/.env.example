# Backend runtime
PORT=3000
NODE_ENV=development

# Security guardrails
# Maximum allowed HTTP request body size in bytes (default: 102400)
MAX_BODY_BYTES=102400

# Login rate limit (per IP + path)
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MS=60000

# Registration rate limit (per IP + path)
REGISTER_RATE_LIMIT_MAX=10
REGISTER_RATE_LIMIT_WINDOW_MS=60000

# VWorld API Configuration
# Get your API key from https://www.vworld.kr/
VWORLD_API_KEY=your_vworld_api_key_here

# NOTE:
# - Never commit real secrets to git.
# - Use local-only .env files for machine-specific values.
